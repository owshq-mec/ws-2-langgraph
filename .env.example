# Quality Guardian (W02) — referência de configuração. Copie p/ .env e preencha a chave.
#   cp .env.example .env  &&  edite ANTHROPIC_API_KEY

# --- LLM do agente (necessário a partir do Passo 6: nó de diagnóstico + evaluator) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Ledger do W01 (Postgres no host :5442) — defaults já batem com o bootstrap ---
GUARDIAN_PG_HOST=localhost
GUARDIAN_PG_PORT=5442
GUARDIAN_PG_DB=dataops
GUARDIAN_PG_USER=dataops
GUARDIAN_PG_PASSWORD=dataops123

# --- Janela de validação (os N mais recentes) ---
GUARDIAN_WINDOW=50

# --- Modelos (evaluator-optimizer: fraco propõe, forte julga) ---
GUARDIAN_LLM_MODEL=anthropic:claude-sonnet-4-6
GUARDIAN_GENERATOR_MODEL=anthropic:claude-haiku-4-5
GUARDIAN_EVALUATOR_MODEL=anthropic:claude-sonnet-4-6
